  fixAdd: concat("name=", replace(tag("name"), "cion", "ción"));
}

*["addr:city"=~/ De /],
*["addr:state"=~/ De /] {
  group: "Preposition in Spanish name";
  throwWarning: "De";
  fixAdd: concat(tr("{0}=", "{0.key}"), replace(tag("{0.key}"), " De ", " de "));
}

*["name"=~/ Y /],
*["addr:city"=~/ Y /],
*["addr:state"=~/ Y /] {
  group: "Preposition in Spanish name";
  throwWarning: "Y";
  fixAdd: concat(tr("{0}=", "{0.key}"), replace(tag("{0.key}"), " Y ", " y "));
}
