/* Spanish accent mark corrections */
*["name"=~/\bCafe\b/] {
  group: "Missing accent mark in Spanish name";
  throwWarning: "Cafe should be Café";
  fixAdd: concat("name=", replace(tag("name"), "Cafe", "Café"));
}

