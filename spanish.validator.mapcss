meta
{
    title: "Spanish name abbreviations and accent marks";
    version: "0.1";
    description: "Random validation rules focused on the Spanish that improve JOSM life.";
    author: "whammo";
    baselanguage: "en";
    min-josm-version: 14481;
    link: "https://github.com/whubsch/custom-josm-rules";
}

*["amenity"="bicycle_rental"],
*["highway"="bus_stop"] {
  set exempt;
}

*["name"=~/\bSta\.?\b/]!.exempt {
  group: "Common abbreviation used in name (Spanish)";
  throwWarning: "Santa";
  fixAdd: concat("name=", replace(replace(tag("name"), "Sta.", "Santa"), "Sta ", "Santa "));
}
